{
  "budget": [
    {
      "path": "/**",
      "timings": [
        {
          "metric": "first-contentful-paint",
          "budget": 2000,
          "tolerance": 500
        },
        {
          "metric": "largest-contentful-paint",
          "budget": 3000,
          "tolerance": 1000
        },
        {
          "metric": "cumulative-layout-shift",
          "budget": 0.1,
          "tolerance": 0.05
        },
        {
          "metric": "first-input-delay",
          "budget": 100,
          "tolerance": 50
        }
      ],
      "resourceSizes": [
        {
          "resourceType": "script",
          "budget": 400000,
          "tolerance": 100000
        },
        {
          "resourceType": "stylesheet",
          "budget": 100000,
          "tolerance": 25000
        },
        {
          "resourceType": "image",
          "budget": 2000000,
          "tolerance": 500000
        },
        {
          "resourceType": "font",
          "budget": 200000,
          "tolerance": 50000
        },
        {
          "resourceType": "total",
          "budget": 5000000,
          "tolerance": 1000000
        }
      ],
      "resourceCounts": [
        {
          "resourceType": "script",
          "budget": 10,
          "tolerance": 5
        },
        {
          "resourceType": "stylesheet",
          "budget": 5,
          "tolerance": 2
        },
        {
          "resourceType": "image",
          "budget": 20,
          "tolerance": 10
        },
        {
          "resourceType": "font",
          "budget": 4,
          "tolerance": 2
        }
      ]
    }
  ],
  "assertions": {
    "categories:performance": ["error", { "minScore": 0.8 }],
    "categories:accessibility": ["error", { "minScore": 0.9 }],
    "categories:best-practices": ["error", { "minScore": 0.8 }],
    "categories:seo": ["error", { "minScore": 0.9 }],
    "categories:pwa": ["warn", { "minScore": 0.6 }]
  },
  "ci": {
    "collect": {
      "numberOfRuns": 3,
      "settings": {
        "preset": "desktop",
        "chromeFlags": "--no-sandbox --disable-dev-shm-usage"
      }
    },
    "assert": {
      "preset": "lighthouse:recommended",
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.8 }],
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "categories:best-practices": ["error", { "minScore": 0.8 }],
        "categories:seo": ["error", { "minScore": 0.9 }]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": "./lighthouse-reports"
    }
  }
}